# ===========================================
# AI Finance Dashboard - Environment Variables
# ===========================================
#
# 두 가지 종류로 분리됩니다.
#   - VITE_ 접두사 = 클라이언트(브라우저) 노출 OK. 무료/공개 데이터 키만.
#   - 접두사 없음   = 서버(Netlify Function) 전용. AI/거래용 비밀 키.
#
# Netlify 배포 시 Site settings → Environment variables 에 동일하게 등록하세요.
# (.env 는 git 에 커밋하지 마세요. 이미 .gitignore 처리됨.)

# ========================================
# AI Provider (서버 전용 — Netlify Function 에서만 사용)
# ========================================
# Tier 라우팅 (자동).
#   - basic     → Gemini 2.5 Flash (무료/저비용)
#   - standard  → Gemini 2.5 Pro (기본 라우팅)
#   - premium   → GPT-4o (사용자 "심층모드" 토글 시만)
#
# 비용 절감 우선 — Gemini 키만으로도 동작합니다. OpenAI 키 없으면 premium 모드 비활성.

# OpenAI (premium 모드 / fallback 용도)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini (기본 라우팅, 무료 tier 권장)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ========================================
# Market Data APIs (클라이언트 노출 OK — 무료 tier)
# ========================================
# Finnhub API (US Stock/ETF prices) — https://finnhub.io
VITE_FINNHUB_API_KEY=your-finnhub-api-key-here

# FRED API (Economic data) — https://fred.stlouisfed.org/docs/api/api_key.html
VITE_FRED_API_KEY=your-fred-api-key-here

# ========================================
# 한국투자증권 OpenAPI (서버 전용)
# ========================================
# Netlify Function 의 kis-token / kis-price / kis-batch 에서만 사용.
# 클라이언트 노출 금지 — VITE_ 접두사 사용하지 않음.
KIS_APP_KEY=your-kis-app-key-here
KIS_APP_SECRET=your-kis-app-secret-here

# ========================================
# Supabase (클라이언트 노출 OK — anon key 만 사용)
# ========================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ========================================
# 마이그레이션 가이드 (기존 사용자)
# ========================================
# 다음 변수들은 더 이상 사용하지 않습니다 (.env 와 Netlify 양쪽 모두에서 제거 권장).
#   VITE_OPENAI_API_KEY   → OPENAI_API_KEY 로 이름 변경 (서버 전용)
#   VITE_OPENAI_MODEL     → OPENAI_MODEL 로 이름 변경
#   VITE_GEMINI_API_KEY   → GEMINI_API_KEY 로 이름 변경
#   VITE_GEMINI_MODEL     → GEMINI_PRO_MODEL 로 이름 변경
#   VITE_AI_PROVIDER      → 사용 안 함 (Tier 라우팅으로 자동 결정)
#   VITE_KIS_APP_KEY      → KIS_APP_KEY 로 이름 변경
#   VITE_KIS_APP_SECRET   → KIS_APP_SECRET 로 이름 변경
